# Netlify Site Environment Variables

# Backend proxy target (Render backend base URL, no trailing /api)
BACKEND_API_URL=https://YOUR_RENDER_BACKEND_URL

# Contact verification
# This site key must be paired with the backend RECAPTCHA_SECRET_KEY from the same Google reCAPTCHA project.
# Configure the Google key to allow your deployed Netlify domain, any custom production domain, and any preview domains that should render the live widget.
REACT_APP_RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
