    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-fontawesome": "^0.2.2",
    "aos": "^2.3.4",
    "clsx": "^2.1.1",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "express-session": "^1.19.0",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-router-dom": "^6.22.1",
    "react-scripts": "5.0.1",
    "request-ip": "^3.3.0",
    "tailwind-merge": "^3.4.0",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^13.5.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "cross-env CI=false react-scripts build",
    "build:analyze": "npm run build && npx webpack-bundle-analyzer build/static/js/*.js",
    "build:production": "npm run build && npm run build:analyze",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "dev": "concurrently \"npm run start:backend\" \"cross-env PORT=3001 npm run start:frontend\"",
    "start:backend": "cd backend && node server.js",
    "start:frontend": "react-scripts start",
    "smoke:rbac": "node backend/scripts/smoke-rbac.js",
    "optimize": "npm run build && npm run build:analyze",
    "lighthouse": "lhci autorun"
  },
  "proxy": "http://localhost:3002",
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
